# Optional: point directly to your TOML file
MIDAS_EXEC_CONFIG=benchmark-ws/strategy.example.toml

# Engine mode: backtest | sim | live
MIDAS_EXEC_MODE=sim
MIDAS_EXEC_CONFIRM_LIVE=false

# You can override any setting from TOML via env:
MIDAS_EXEC_TICKER=MES
MIDAS_EXEC_DATA_FILE=data/train/MES.parquet
MIDAS_EXEC_POINT_VALUE=5
MIDAS_EXEC_TICK_SIZE=0.25

# Tradovate sim wiring
MIDAS_EXEC_SIM_CONTRACT=MESH6
MIDAS_EXEC_SIM_WS_URL=wss://md.tradovateapi.com/v1/websocket
MIDAS_EXEC_SIM_REST_URL=https://demo.tradovateapi.com/v1
MIDAS_EXEC_LIVE_WS_URL=wss://md.tradovateapi.com/v1/websocket
MIDAS_EXEC_LIVE_REST_URL=https://live.tradovateapi.com/v1
MIDAS_EXEC_SIM_TOKEN_PATH=.auth/bearer-token.json
# MIDAS_EXEC_SIM_ACCOUNT_SPEC=SIM12345
# MIDAS_EXEC_SIM_ACCOUNT_ID=123456
MIDAS_EXEC_SIM_HISTORY_BARS=500
MIDAS_EXEC_SIM_MAX_RUNTIME_SECONDS=1800
MIDAS_EXEC_SIM_HEARTBEAT_MS=2500
MIDAS_EXEC_SIM_ORDER_TIF=Day
MIDAS_EXEC_SIM_DRY_RUN=true

# Risk/trailing examples:
MIDAS_EXEC_USE_TRAILING_STOP=true
MIDAS_EXEC_TRAIL_TRIGGER_TICKS=10
MIDAS_EXEC_TRAIL_OFFSET_TICKS=0

# Export overrides:
MIDAS_EXEC_EXPORT_TRADES_CSV=runs/mes_trades.csv
MIDAS_EXEC_EXPORT_EQUITY_CSV=runs/mes_equity.csv
